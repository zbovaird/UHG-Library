include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml
include requirements.txt
include UHG.pdf
include "UHG pictorial.pdf"

# Package data
recursive-include uhg *.py
recursive-include uhg *.pyi
recursive-include uhg py.typed

# Exclude non-library content from distributions
prune examples
prune tests
prune benchmarks
prune use_cases
prune scripts

# Global excludes
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude .git
global-exclude .ipynb_checkpoints
global-exclude .DS_Store
global-exclude __pycache__
global-exclude .coverage
global-exclude *.log
global-exclude .pytest_cache
global-exclude .tox
global-exclude .venv
global-exclude build
global-exclude dist
